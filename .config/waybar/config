{
  "height": 34,
  "spacing": 10,
  "reload_style_on_change": true,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["custom/vpn", "cpu", "memory", "pulseaudio"],

  "custom/vpn": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/waybar-vpn.sh",
    "interval": 10,
    "return-type": "json",

    "signal": 8,
    "on-click": "sh -c '/usr/bin/mullvad status | grep -q Connected && /usr/bin/mullvad disconnect || /usr/bin/mullvad connect; pkill -RTMIN+8 waybar'"
  },
  "clock": {
    "format": "{:%A %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%Y-%m-%d}"
  },

  "cpu": {
    "interval": 1,
    "format": "  {usage}%",
    "tooltip": true
  },

  "memory": {
    "format": "  {used:0.1f}G/{total:0.1f}G",
    "tooltip": true
  },

  "pulseaudio": {
    // "format": "{volume}% {icon} ({sink_description})",
    // "scroll-step": 1, // %, can be a float
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} {volume}% 󰂯", // {format_source}
    "format-bluetooth-muted": "󰖁 {icon} 󰂯", // {format_source}
    "format-muted": "󰖁 {volume}%",
    // "format-source": " {volume}%",
    // "format-source-muted": "",
    "format-icons": {
      "headphone": "󰋋",
      "hands-free": "󱡒",
      "headset": "󰋎",
      "default": ["", "", ""]
    },
    "on-click": "pavucontrol"
  },

"hyprland/workspaces": {
    "format": "{name}",
    "all-outputs": true,
    "sort-by-number": true,
    "persistent-workspaces": {
      "*": 5 // Adjust to how many you want
    }
  }
}
